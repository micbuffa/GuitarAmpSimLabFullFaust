declare name      "Tube Emulation Library (100% Faust)";
declare author    "Generated automatically from Guitarix C++ arrays";
declare license   "LGPL";

import("stdfaust.lib");

// Helper to read from waveform with lin-interpolation
// Assumes table has size, low, high, istep as params
rdtable_interpolated(wf, low, high, istep, tsize, Vgk) = res
with {
    f = (Vgk - low) * istep;
    i = int(f);
    
    // Bounds check
    is_low = f < 0.0;
    is_high = f >= float(tsize - 1);
    
    i_safe = max(0, min(tsize - 2, i));
    
    f_rem = max(0.0, min(1.0, f - float(i_safe)));
    
    val0 = wf, i_safe : rdtable;
    val1 = wf, i_safe + 1 : rdtable;
    interp = val0 * (1.0 - f_rem) + val1 * f_rem;
    
    res = select2(is_low, 
             select2(is_high, interp, (wf, tsize-1 : rdtable)), 
             (wf, 0 : rdtable));
};

