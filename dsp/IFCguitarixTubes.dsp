// Explanations:
// Vin  
//   │ 
//   ▼
// [Cgk] → Grille (g)
//          │
//         [Triode]  ──── Ia(Vgk) courbe caractéristique
//          │
//         Cathode (k)  ──── [Rk] ── GND  (résistance de cathode)
//                                  [Ck] en parallèle (condensateur de bypass)
//          │
//         Plaque (p)  ──── [Rp = 100kΩ] ──── Vplus (tension d'alimentation ≈ +250V)
//          │
//        Vout (via condensateur de couplage)
//
//
// Rp = 100.0e3 (résistance de plaque)
//      Valeur fixe : 100 kΩ — la résistance de charge en plaque du circuit 
//      Guitarix
//      C'est elle qui, avec la pente de la courbe Ia(Vgk), détermine le gain de 
//      l'étage. Plus Rp est grande → plus le gain est élevé
//
// Vk0 (tension de cathode au point de repos)
//      La tension DC aux bornes de Rk sans signal : Vk0 = Ia_repos × Rk
//      Pour une 12AX7 stage 1 : Vk0 = 1.581656 V
//      Définit le point de fonctionnement (operating point / quiescent point) 
//      sur la courbe Ia(Vgk)
//
// VkC = Vk0 * (Rp/Rk) (tension de plaque au repos)
//      C'est la tension de plaque normalisée au repo, calculée par diviseur 
//      de tension : Vp_repos = Vplus - Ia_repos × Rp
//      soit dans la formulation normalisée du code : VkC = Vk0 × (Rp/Rk)
//
// vplus et divider
//          Valeur	tubestage	tubestage130_20
//          vplus	250.0 V 	130.0 V
//          divider	40.0	    20.0
//
// vplus = tension d'alimentation B+ du tube (250V typique, 130V pour 6DJ8 à 
//         plus basse tension)

// divider = facteur de normalisation de sortie → ramène le signal de la 
//           plaque (~0–250V) à une amplitude audio normalisée (÷40 → ~0–6V, 
//           puis le reste de la chaîne gère)
//
// fck — fréquence de coupure du filtre cathode
//       Fréquence du condensateur de bypass de cathode Ck
//       lpfk = fi.lowpass(1, fck) — simule la charge RC de la cathode
// Exemples :
//        Stage 1 (Rk=2700Ω, fck=86 Hz) → condensateur de bypass peu efficace 
//              aux graves
//        Stage 3 (Rk=820Ω, fck=194 Hz) → bypass plus rapide, plus de gain sur 
//              toute la bande
//
// Rk — résistance de cathode
//        2700Ω pour stage 1, 1500Ω pour stage 2, 820Ω pour stage 3
//        Plus Rk est grande → plus le point de repos est "froid" → plus la 
//        distorsion est asymétrique et douce
//
// ------------------------------------------
// La boucle de feedback : le cœur du modèle
// (modélise la  contre-réaction cathode (boucle ~))
//
// tube = (+ : -(Vk0) : FtubeCurve : +(VkC-vplus)) ~ (*(Rk/Rp) : lpfk) : /(divider);
// 
// Décomposons :
// signal_entrant → [+] → [-(Vk0)] → [FtubeCurve] → [+(VkC - vplus)] → ÷divider → sortie
//                  ↑                                         │
//                  └──────── [lpfk] ← [×(Rk/Rp)] ←─────────┘
//                            (feedback cathode filtré)
//
// Chaque bloc dans l'ordre :
//
// + — additionne le signal audio ET le feedback cathode (boucle ~)
// 
// -(Vk0) — soustrait la tension de repos de cathode → centre la courbe autour du 
//          point de fonctionnement → c'est Vgk = Vg - Vk
// 
// FtubeCurve — applique la courbe Ia(Vgk) lue depuis la wavetable → c'est ici 
//          que la non-linéarité / saturation se produit
// 
// +(VkC - vplus) — translate la sortie vers la tension de plaque au repos 
//          (DC restore)
// 
// ÷ divider — normalise le niveau de sortie
// 
// La boucle ~ :
// 
// - Prend la sortie de plaque (après FtubeCurve + décalage)
// - Multiplie par Rk/Rp → proportionne le courant de cathode
// - Passe par lpfk = lowpass(fck) → simule le condensateur de bypass de cathode 
//   Ck
// - Est réinjectée en entrée du + → c'est la contre-réaction naturelle de la 
//   cathode (negative feedback)
//----------------------------------
// Le filtre passe-haut de sortie (hpf = fi.highpass(1, 31.0);
//      FC = 31 Hz → simule le condensateur de couplage de sortie (typiquement 
//      22–47 nF dans un vrai circuit)
//      Élimine la composante DC de sortie → évite la saturation des étages 
//      suivants.
//      Ne touche pas au son audible (31 Hz bien en dessous du grave de guitare 
//      utile)
//
// Les deux variantes :
// tubestage(FtubeCurve, fck, Rk, Vk0) = 
//                      tubestageF(FtubeCurve, 250.0, 40.0, fck, Rk, Vk0);
// tubestage130_20(FtubeCurve, fck, Rk, Vk0) = 
//                      tubestageF(FtubeCurve, 130.0, 20.0, fck, Rk, Vk0);
// 
// tubestage → alimentation à 250V, division par 40 → pour 12AX7, 12AT7, 12AU7, 
//             6V6, 6C16
// tubestage130_20 → alimentation à 130V, division par 20 → pour 6DJ8 qui opère 
//             à plus basse tension (c'est une triode Hi-Fi de radio, pas prévue 
//             pour 250V)
// 
// Effet audible global du modèle
//
// FtubeCurve non linéaire	: Distorsion harmonique caractéristique du tube : 
//                          H2 (douce, "chaleureuse") dominant
// Boucle feedback cathode Rk/Rp × lpf	: Compression naturelle, "squish" sur 
//                                        les transitoires — le tube "respire"
// fck du bypass cathode	: Plus fck est bas → plus les graves sont compressés → 
//                            son plus "serré" en bas
// Vk0 (point de repos)	: Plus élevé → asymétrie plus forte → plus de H2 → 
//                        saturation plus "tube"
// Rk élevé (stage 1 → 2700Ω)	: Stage plus doux, headroom élevé, compression 
//                                lente
// Rk faible (stage 3 → 820Ω)	: Stage plus agressif, montée en distorsion plus 
//                                vive

tubestageF(FtubeCurve,vplus,divider,fck,Rk,Vk0) = tube : hpf with {
    lpfk = fi.lowpass(1,fck);
    Rp = 100.0e3;
    VkC = Vk0 * (Rp/Rk);
    tube = (+ : -(Vk0) : FtubeCurve : +(VkC-vplus)) ~ (*(Rk/Rp) : lpfk) : /(divider);
    hpf = fi.highpass(1,31.0);
};

tubestage(FtubeCurve,fck,Rk,Vk0)       = tubestageF(FtubeCurve,250.0,40.0,fck,Rk,Vk0);
tubestage130_20(FtubeCurve,fck,Rk,Vk0) = tubestageF(FtubeCurve,130.0,20.0,fck,Rk,Vk0);

