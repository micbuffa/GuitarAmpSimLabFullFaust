// --- UI ---
bypass = hgroup("Cabinet Simulator", checkbox("Bypass[stratus:0]"));
selected_cab = hgroup("Cabinet Simulator", nentry("Cabinet Select[stratus:1][style:menu{'fenderDeluxeJensen1x12':0;'Mesa-OS-Rectifier-3':1;'Marshall1960':2}]", 0, 0, 2, 1));
mix = hgroup("Cabinet Simulator", hslider("Mix (Dry/Wet)[stratus:2]", 1, 0, 1, 0.01)) : si.smoo;
gain = hgroup("Cabinet Simulator", hslider("Output (dB)[stratus:3]", 0, -20, 10, 0.1)) : ba.db2linear : si.smoo;

// --- ROUTING ---
// Send the input to all FIR, and select the output signal
cab_gain = 2.83386278, 3.28121114, 3.01341939 : ba.selectn(3, selected_cab);

cab_process = _ <: (dry, wet) : + : *(gain)
with {
    dry = *(1 - mix);
    wet = _ <: (fir_0, fir_1, fir_2) : ba.selectn(3, selected_cab) : *(mix);
};

bypassed_process = _ * cab_gain;

cab_process_final = _ <: select2(bypass, cab_process, bypassed_process);

cabSimMB = vgroup("Speaker simulation", cab_process_final);

//process = cabSimMB;